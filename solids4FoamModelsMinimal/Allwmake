#!/bin/bash
set -e
cd "${0%/*}" || exit 1
REPO_ROOT=$(cd .. && pwd)
DEFAULT_S4F_ROOT="$REPO_ROOT/external/solids4foam"

# Parse arguments for library compilation
if [ -f "$WM_PROJECT_DIR"/wmake/scripts/AllwmakeParseArguments ]
then
    . "$WM_PROJECT_DIR"/wmake/scripts/AllwmakeParseArguments
fi

S4F_ROOT="${S4F_ROOT:-$DEFAULT_S4F_ROOT}"
case "$S4F_ROOT" in
    /*) ;;
    *) S4F_ROOT="$REPO_ROOT/$S4F_ROOT" ;;
esac

if [ ! -d "$S4F_ROOT/src/solids4FoamModels" ] && [ -d "$DEFAULT_S4F_ROOT/src/solids4FoamModels" ]
then
    echo "Warning: S4F_ROOT '$S4F_ROOT' is invalid; falling back to '$DEFAULT_S4F_ROOT'"
    S4F_ROOT="$DEFAULT_S4F_ROOT"
fi

export S4F_ROOT
S4F_MODELS_DIR="$S4F_ROOT/src/solids4FoamModels"
S4F_BLOCK_TOOLS_DIR="$S4F_ROOT/src/blockCoupledSolids4FoamTools"

if [ ! -d "$S4F_MODELS_DIR" ]
then
    echo "Missing solids4Foam sources at $S4F_MODELS_DIR"
    echo "Set S4F_ROOT to an existing solids4Foam source or initialize the submodule."
    exit 1
fi

if [ ! -d "$S4F_BLOCK_TOOLS_DIR" ]
then
    echo "Missing solids4Foam sources at $S4F_BLOCK_TOOLS_DIR"
    echo "Set S4F_ROOT to an existing solids4Foam source or initialize the submodule."
    exit 1
fi

# Directly compile the selected upstream sources; only header lnIncludes are prepared here.
wmakeLnInclude "$S4F_MODELS_DIR"
wmakeLnInclude "$S4F_BLOCK_TOOLS_DIR"

wmake $targetType libso
