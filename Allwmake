#!/bin/bash
cd ${0%/*} || exit 1    # run from this directory
REPO_ROOT=$(pwd)
DEFAULT_S4F_ROOT="$REPO_ROOT/external/solids4foam"

# Stop at first error
set -e

# Check if OpenFOAM/FOAM has been sourced
if [[ -z "${WM_PROJECT}" ]]
then
    echo "OpenFOAM environment is not sourced."
    echo "Source the OpenFOAM/FOAM bashrc first, then rerun ./Allwmake."
    exit 1
else
    if [[ "$WM_PROJECT_VERSION" != "v2412" && "$WM_PROJECT_VERSION" != "v2512" ]]; then
        echo "Unsupported OpenFOAM version detected: WM_PROJECT=$WM_PROJECT, WM_PROJECT_VERSION=$WM_PROJECT_VERSION"
        echo "poroMechanicalFoam currently supports OpenFOAM v2412 and v2512."
        exit 1
    fi
fi

# Parse arguments for library compilation
if [ -f "$WM_PROJECT"/wmake/scripts/AllwmakeParseArguments ]
then  . "$WM_PROJECT"/wmake/scripts/AllwmakeParseArguments
fi

check_build_log()
{
    stage_name=$1
    log_file=$2

    if grep -q "\ Error\ " "$log_file" || grep -q "\ Stop." "$log_file"
    then
        echo "** BUILD ERROR **"
        echo "Build stage failed: $stage_name"
        echo "Log file: $log_file"
        echo "Review the first compiler or linker error in that log and rerun ./Allwmake."
        exit 1
    fi
}

# Use local submodule by default, unless caller provides an existing solids4Foam path.
S4F_ROOT="${S4F_ROOT:-$DEFAULT_S4F_ROOT}"
case "$S4F_ROOT" in
    /*) ;;
    *) S4F_ROOT="$REPO_ROOT/$S4F_ROOT" ;;
esac

if [ ! -d "$S4F_ROOT/src/solids4FoamModels" ] && [ -d "$DEFAULT_S4F_ROOT/src/solids4FoamModels" ]
then
    echo "Warning: S4F_ROOT '$S4F_ROOT' does not contain src/solids4FoamModels."
    echo "Falling back to '$DEFAULT_S4F_ROOT'."
    S4F_ROOT="$DEFAULT_S4F_ROOT"
fi

export S4F_ROOT

# Check to see if Umats should be compiled
if [[ ! -z "${S4F_USE_GFORTRAN+x}" ]]
then
    (
        set -o pipefail
        cd abaqusUMATs && ./Allwmake "$@" 2>&1 | tee log.Allwmake
    )
else
    echo
    echo "S4F_USE_GFORTRAN is not set: skipping abaqusUMATs."
    echo "If you need the Abaqus UMATs, install gfortran and set S4F_USE_GFORTRAN=1 before running ./Allwmake."
    echo
fi

# Compile poroHydraulicModel
(
    set -o pipefail
    cd materialModels/poroHydraulicModel/ && wmake libso "$@" 2>&1 | tee log.Allwmake
)
check_build_log "poroHydraulicModel library" "$REPO_ROOT/materialModels/poroHydraulicModel/log.Allwmake"

# Set up solids4foam submodule with sparse checkout if needed
if [ "$S4F_ROOT" = "$REPO_ROOT/external/solids4foam" ]; then
    if [ ! -d "$S4F_ROOT/src/solids4FoamModels" ]; then
        echo "Initialising solids4foam submodule (sparse checkout: src/solids4FoamModels, src/blockCoupledSolids4FoamTools)..."

        # Older Git versions do not support --no-checkout on submodule update.
        git submodule update --init external/solids4foam

        if git -C external/solids4foam sparse-checkout -h >/dev/null 2>&1; then
            git -C external/solids4foam sparse-checkout init --cone
            git -C external/solids4foam sparse-checkout set src/solids4FoamModels src/blockCoupledSolids4FoamTools
        else
            git -C external/solids4foam config core.sparseCheckout true
            SPARSE_FILE=$(git -C external/solids4foam rev-parse --git-path info/sparse-checkout)
            mkdir -p "$(dirname "$SPARSE_FILE")"
            cat > "$SPARSE_FILE" <<'EOF'
/src/solids4FoamModels/
/src/blockCoupledSolids4FoamTools/
EOF
            git -C external/solids4foam read-tree -mu HEAD
        fi

        git -C external/solids4foam checkout v2.3
        echo "solids4foam submodule ready at: $S4F_ROOT"
    fi
fi

# Prepare upstream solids4foam lnInclude trees before any dependent build.
if [ -d "$S4F_ROOT/src/solids4FoamModels" ]; then
    wmakeLnInclude "$S4F_ROOT/src/solids4FoamModels"
fi

if [ -d "$S4F_ROOT/src/blockCoupledSolids4FoamTools" ]; then
    wmakeLnInclude "$S4F_ROOT/src/blockCoupledSolids4FoamTools"
fi

# Compile the pinned solids4Foam minimal subset library
(
    set -o pipefail
    cd solids4FoamModelsMinimal && ./Allwmake "$@" 2>&1 | tee log.Allwmake
)
check_build_log "solids4FoamModelsMinimal library" "$REPO_ROOT/solids4FoamModelsMinimal/log.Allwmake"

# Compile poroMechanicalFoam Library
(
    set -o pipefail
    wmake libso "$@" 2>&1 | tee log.Allwmake
)
check_build_log "poroMechanicalFoam library" "$REPO_ROOT/log.Allwmake"


# Compile poroMechanicalFoam application
(
    set -o pipefail
    cd solvers && ./Allwmake "$@" 2>&1 | tee log.Allwmake
)
check_build_log "solver applications" "$REPO_ROOT/solvers/log.Allwmake"

##(cd abaqusUMATs && ./Allwmake)

# Check if the build succeeded
echo "Checking if the installation was a success:"
N_ERRORS_1=$(find . -name log.Allwmake | xargs grep "\ Error\ " | wc -l)
N_ERRORS_2=$(find . -name log.Allwmake | xargs grep "\ Stop." | wc -l)
if [[ $N_ERRORS_1 -gt 0 ]] || [[ $N_ERRORS_2 -gt 0 ]]
then
    echo "** BUILD ERROR **"
    echo "There were build errors in the following logs:"
    echo $(find . -name log.Allwmake | xargs grep -l "\ Error\ ")
    echo $(find . -name log.Allwmake | xargs grep -l "\ Stop.")
    echo
    echo "Please examine these logs for the first compiler or linker failure and rerun ./Allwmake."
    echo
    exit 1
else
    echo "There were no build errors. poroMechanicalFoam is ready to use."
    echo
fi
echo
