FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      poroHydraulicProperties;
}

rho     rho [1 -3 0 0 0 0 0] 1000;
href    href [0 1 0 0 0 0 0] 0;

// Top-level entries are used as default values for the auto-created
// defaultZone (no cellZones required). For multi-zone meshes, add a
// named sub-dict per zone that overrides these defaults.

n               n [0 0 0 0 0 0 0] 0.35;
storageLaw      storageCoeff;
conductivityLaw constant;

storageCoeffCoeffs
{
    Ss          Ss [-1 1 2 0 0 0 0] 1e-5;
}

k       k [0 1 -1 0 0 0 0] 1e-5;
