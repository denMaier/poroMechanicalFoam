FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application     poroMechanicalFoam;

startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         10;
deltaT          0.1;

writeControl    timeStep;
writeInterval   10;
purgeWrite      0;

writeFormat     ascii;
writePrecision  8;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;

adjustTimeStep  no;

