#!/usr/bin/env bash
set -euo pipefail

allowed_domain='@baw.de'
email_regex='[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}'

violations="$(
    git grep --cached -nI -E "$email_regex" -- . ':(exclude)external/solids4foam' \
        | grep -v --fixed-strings "$allowed_domain" || true
)"

if [[ -n "$violations" ]]; then
    printf 'pre-commit: staged content contains email addresses outside %s:\n' \
        "$allowed_domain" >&2
    printf '%s\n' "$violations" >&2
    exit 1
fi
