S4F_ROOT ?= $(WM_PROJECT_DIR)/../poroMechanicalFoam/external/solids4foam
S4F_SRC ?= $(S4F_ROOT)/src

VERSION_SPECIFIC_INC = \
    -DOPENFOAM_NOT_EXTEND \
    -DOPENFOAM_COM \
    -DOPENFOAMESIORFOUNDATION \
    -DOPENFOAMESI \
    -I$(LIB_SRC)/dynamicFvMesh/lnInclude/

ifdef S4F_USE_GFORTRAN
    GFORTRAN_LIBS = \
        -lgfortran \
        $(FOAM_USER_LIBBIN)/abaqusUmatMohrCoulomb.o \
        -labaqusUmatMohrCoulomb
endif

EXE_INC = \
    -I$(S4F_SRC)/solids4FoamModels/lnInclude \
    -I../../lnInclude \
    -I../../materialModels/poroHydraulicModel/lnInclude \
    $(VERSION_SPECIFIC_INC) \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/finiteArea/lnInclude \
    -I$(LIB_SRC)/lagrangian/lnInclude \
    -I$(LIB_SRC)/dynamicMesh/lnInclude \
    -I$(LIB_SRC)/dynamicMesh/dynamicMesh/lnInclude \
    -I$(LIB_SRC)/dynamicMesh/dynamicFvMesh/lnInclude \
    -I$(LIB_SRC)/dynamicFvMesh/lnInclude \
    -I$(LIB_SRC)/dynamicMesh/topoChangerFvMesh/lnInclude \
    -I$(LIB_SRC)/sampling/lnInclude \
    -I$(LIB_SRC)/postProcessing/foamCalcFunctions/lnInclude \
    -I$(LIB_SRC)/postProcessing/functionObjects/forces/lnInclude \
    -I../../../lnInclude

EXE_LIBS = \
    -L$(FOAM_USER_LIBBIN) \
    -lfiniteVolume \
    -lsolids4FoamModelsMinimal \
    -lporoHydraulicModels \
    -lporoModels  \
    -lmeshTools \
    -lsampling \
    $(GFORTRAN_LIBS)
