#!/bin/bash
cd ${0%/*} || exit 1    # run from this directory
REPO_ROOT=$(pwd)
DEFAULT_S4F_ROOT="$REPO_ROOT/external/solids4foam"

# Stop at first error
set -e

# Check if OpenFOAM/FOAM has been sourced
if [[ -z "${WM_PROJECT}" ]]
then
    echo "Please source the OpenFOAM/FOAM bashrc first!"
    exit 1
else
    if [[ "$WM_PROJECT_VERSION" != "v2412" && "$WM_PROJECT_VERSION" != "v2512" ]]; then
        echo "Unsupported OpenFOAM version sourced! poroMechanicalFoam supports OpenFOAM v2412 and v2512."
        exit 1
    fi
fi

# Parse arguments for library compilation
if [ -f "$WM_PROJECT"/wmake/scripts/AllwmakeParseArguments ]
then  . "$WM_PROJECT"/wmake/scripts/AllwmakeParseArguments
fi

# Use local submodule by default, unless caller provides an existing solids4Foam path.
S4F_ROOT="${S4F_ROOT:-$DEFAULT_S4F_ROOT}"
case "$S4F_ROOT" in
    /*) ;;
    *) S4F_ROOT="$REPO_ROOT/$S4F_ROOT" ;;
esac

if [ ! -d "$S4F_ROOT/src/solids4FoamModels" ] && [ -d "$DEFAULT_S4F_ROOT/src/solids4FoamModels" ]
then
    echo "Warning: S4F_ROOT '$S4F_ROOT' is invalid; falling back to '$DEFAULT_S4F_ROOT'"
    S4F_ROOT="$DEFAULT_S4F_ROOT"
fi

export S4F_ROOT

# Check to see if Umats should be compiled
if [[ ! -z "${S4F_USE_GFORTRAN+x}" ]]
then
    (
        set -o pipefail
        cd abaqusUMATs && ./Allwmake "$@" 2>&1 | tee log.Allwmake
    )
else
    echo; echo "The S4F_USE_GFORTRAN variable is not set: skipping abaqusUMATs"
    echo "To use abaqusUMATs, install gfortran and set the S4F_USE_GFORTRAN "
    echo "variable to 1"; echo
fi

# Compile poroHydraulicModel
(
    set -o pipefail
    cd materialModels/poroHydraulicModel/ && wmake libso "$@" 2>&1 | tee log.Allwmake
)

# Set up solids4foam submodule with sparse checkout if needed
if [ "$S4F_ROOT" = "$REPO_ROOT/external/solids4foam" ]; then
    if [ ! -d "$S4F_ROOT/src/solids4FoamModels" ]; then
        echo "Initialising solids4foam submodule (sparse checkout: src/solids4FoamModels)..."
        git submodule update --init --no-checkout external/solids4foam
        git -C external/solids4foam sparse-checkout init --cone
        git -C external/solids4foam sparse-checkout set src/solids4FoamModels
        git -C external/solids4foam checkout v2.3
        echo "solids4foam submodule ready."
    fi
fi

# Compile the pinned solids4Foam minimal subset library
(
    set -o pipefail
    cd solids4FoamModelsMinimal && ./Allwmake "$@" 2>&1 | tee log.Allwmake
)

# Compile poroMechanicalFoam Library
(
    set -o pipefail
    wmake libso "$@" 2>&1 | tee log.Allwmake
)


# Compile poroMechanicalFoam application
(
    set -o pipefail
    cd solvers && ./Allwmake "$@" 2>&1 | tee log.Allwmake
)

##(cd abaqusUMATs && ./Allwmake)

# Check if the build succeeded
echo "Checking if the installation was a success:"
N_ERRORS_1=$(find . -name log.Allwmake | xargs grep "\ Error\ " | wc -l)
N_ERRORS_2=$(find . -name log.Allwmake | xargs grep "\ Stop." | wc -l)
if [[ $N_ERRORS_1 -gt 0 ]] || [[ $N_ERRORS_2 -gt 0 ]]
then
    echo "** BUILD ERROR **"
    echo "There were build errors in the following logs:"
    echo $(find . -name log.Allwmake | xargs grep -l "\ Error\ ")
    echo $(find . -name log.Allwmake | xargs grep -l "\ Stop.")
    echo; echo "Please examine these logs for additional details"; echo
    exit 1
else
    echo "There were no build errors: enjoy poroMechanicalFoam!"; echo
fi
echo
