FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      pHead;
}

dimensions      [0 1 0 0 0 0 0];

internalField   uniform -0.5;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0;
    }

    outlet
    {
        type            zeroGradient;
    }

    walls
    {
        type            zeroGradient;
    }

    frontAndBack
    {
        type            empty;
    }
}

